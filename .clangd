CompileFlags:
  CompilationDatabase: "build/"
  Add:
    # - "-nogpuinc"
    # - "-nogpulib"
    - --cuda-path=/opt/watchdog/users/parth/cuda13.1
    - --cuda-gpu-arch=sm_100a
    - -xcuda
    - -std=c++20
    - "-I/opt/watchdog/users/parth/cuda13.1/include"
    - "-I/opt/watchdog/users/parth/cuda13.1/include/cccl"
    - "--cuda-path=/opt/watchdog/users/parth/cuda13.1"

  Remove:
    - -forward-unknown-to-host-compiler
    - --generate-code*
    - -ccbin*

Diagnostics:
  Suppress:
    - unknown_typename
    - drv_unknown_argument
    - cuda_unknown_type